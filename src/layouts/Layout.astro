---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Olympus Gallery — Samtidskonst i Stockholm',
  description = 'Ett galleri för samtidskonst med hemvist i Stockholm. Vi ställer ut verk som tål att betraktas länge — måleri, skulptur, fotografi och installation.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap"
    />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('consent','default',{'analytics_storage':'denied','wait_for_update':500});
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        gtag('consent','update',{'analytics_storage':'granted'});
      }
    </script>
  </head>
  <body>
    <slot />
    <script src="/js/olympus.js" defer is:inline></script>
  </body>
</html>
