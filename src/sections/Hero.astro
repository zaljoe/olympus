---
const tagline = "Ett galleri för samtidskonst med <em>djup respekt för hantverket</em>. Vi ställer ut verk som stannar kvar — i rummet, i minnet och i samlingen.";

const tickerItems = ["Måleri","★","Skulptur","★","Fotografi","★","Installation","★","Grafik","★","Textil","★","Samtidskonst","★"];
---

<section class="hero">

  <div class="hero-plate">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline
      preload="auto"
      poster="/images/hero.webp"
      aria-hidden="true"
    >
      <source src="/images/hero.webm" type="video/webm" />
      <source src="/images/hero.mp4" type="video/mp4" />
    </video>
    <img
      class="hero-poster"
      src="/images/hero.webp"
      alt=""
      aria-hidden="true"
    />
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="hero-scrim-bottom" aria-hidden="true"></div>
  </div>

  <div class="plate-index">
    <div class="plate-index-num">I</div>
    <div class="plate-index-label">
      <div>Verk I · Väktaren av ljuset</div>
      <div class="sub">Olja på linne · Förvärvat MMXXIV</div>
    </div>
  </div>

  <div class="hero-content">
    <div class="eyebrow">
      <span class="rule-line" aria-hidden="true"></span>
      <span>Säsong VII — Vår MMXXVI</span>
    </div>

    <h1 class="hero-title">
      <span class="line">Konst som</span>
      <span class="line italic">talar när</span>
      <span class="line"><span class="gold">ord</span> inte</span>
      <span class="line">räcker.</span>
    </h1>

    <p class="hero-lede" set:html={tagline} />

    <div class="hero-actions">
      <a class="btn btn-primary" href="#samling">
        <span>Se samlingen</span>
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
          <path d="M1 5 H12 M8 1 L12 5 L8 9" stroke="currentColor" stroke-width="1.3"/>
        </svg>
      </a>
      <a class="btn btn-ghost" href="#forvärva">
        <span>Förvärva ett verk</span>
      </a>
    </div>
  </div>

  <div class="hero-strip">
    <div class="strip-left">
      <div class="strip-col">
        <div class="k">Grundat</div>
        <div class="v">Stockholm · 2019</div>
      </div>
      <div class="strip-col">
        <div class="k">Samlingen</div>
        <div class="v">340+ verk</div>
      </div>
      <div class="strip-col">
        <div class="k">Discipliner</div>
        <div class="v">Måleri · Skulptur · Foto</div>
      </div>
    </div>
    <div class="strip-right">
      <span class="cap-greek">Ἡ τέχνη μακρὰ, ὁ βίος βραχύς.</span>
      <span class="cap-en">Art is long — life, brief.</span>
    </div>
  </div>

  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[0, 1, 2, 3].map((_) => (
        <div class="ticker-run">
          {tickerItems.map((t) => (
            <span class={t === "★" ? "star" : ""}>{t}</span>
          ))}
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    margin: 0;
    padding: 0;
    background: #0e1a1d;
    color: var(--bone);
    overflow: hidden;
    margin-top: -70px;
    padding-top: 70px;
  }

  /* Full-bleed plate */
  .hero-plate {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-plate video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }
  .hero-poster {
    display: none;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg,
      rgba(14,26,29,0.9) 0%,
      rgba(14,26,29,0.78) 25%,
      rgba(14,26,29,0.45) 48%,
      rgba(14,26,29,0.1) 68%,
      rgba(14,26,29,0) 100%);
  }
  .hero-scrim-bottom {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 42%;
    background: linear-gradient(180deg, rgba(14,26,29,0) 0%, rgba(14,26,29,0.7) 100%);
    pointer-events: none;
  }

  /* Plate index label */
  .plate-index {
    position: absolute;
    top: 110px;
    left: 56px;
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--bone);
    z-index: 3;
  }
  .plate-index-num {
    font-family: var(--font-display);
    font-size: 56px;
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    color: var(--gold-soft);
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .plate-index-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(244,236,222,0.88);
    line-height: 1.45;
    padding-left: 14px;
    border-left: 1px solid rgba(244,236,222,0.28);
  }
  .plate-index-label .sub {
    color: rgba(244,236,222,0.55);
    margin-top: 2px;
  }

  /* Hero content */
  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 1320px;
    margin: 0 auto;
    padding: 200px 56px 56px;
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(244,236,222,0.78);
    margin-bottom: 28px;
  }
  .rule-line {
    width: 38px;
    height: 1px;
    background: var(--gold-soft);
    opacity: 0.8;
    display: block;
  }

  /* Title */
  .hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(64px, 8.4vw, 132px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--bone);
    text-shadow: 0 2px 40px rgba(0,0,0,0.35);
    max-width: 12ch;
  }
  .hero-title .line { display: block; }
  .hero-title .italic {
    font-style: italic;
    font-weight: 300;
    color: rgba(244,236,222,0.94);
  }
  .hero-title .gold {
    color: var(--gold-soft);
    font-style: italic;
    font-weight: 400;
    position: relative;
    display: inline-block;
    padding-right: 0.25em;
  }
  .hero-title .gold::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 0.1em;
    height: 2px;
    background: linear-gradient(90deg, var(--gold-soft), transparent 80%);
    opacity: 0.55;
  }

  /* Lede */
  .hero-lede {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.55;
    font-weight: 300;
    color: rgba(244,236,222,0.88);
    max-width: 46ch;
    margin: 0 0 36px;
    text-wrap: pretty;
  }
  .hero-lede :global(em) { color: var(--gold-soft); font-style: italic; }

  /* Actions */
  .hero-actions { display: flex; gap: 14px; }

  /* Bottom strip */
  .hero-strip {
    position: relative;
    z-index: 3;
    max-width: 1320px;
    margin: 0 auto;
    padding: 28px 56px;
    border-top: 1px solid rgba(244,236,222,0.18);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: center;
  }
  .strip-left {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 48px;
  }
  .strip-col .k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(244,236,222,0.55);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .strip-col .v {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    color: var(--bone);
  }
  .strip-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    text-align: right;
  }
  .cap-greek {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--gold-soft);
  }
  .cap-en {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: rgba(244,236,222,0.5);
    text-transform: uppercase;
  }

  /* Ticker */
  .ticker {
    position: relative;
    z-index: 3;
    margin: 0;
    padding: 18px 0;
    border-top: 1px solid rgba(244,236,222,0.18);
    border-bottom: 1px solid rgba(244,236,222,0.12);
    overflow: hidden;
    background: rgba(14,22,25,0.75);
    backdrop-filter: blur(6px);
  }
  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll 40s linear infinite;
  }
  .ticker-run {
    display: flex;
    align-items: center;
    gap: 36px;
    padding-right: 36px;
    font-family: var(--font-display);
    font-size: 26px;
    font-style: italic;
    font-weight: 300;
    color: rgba(244,236,222,0.88);
    white-space: nowrap;
  }
  .ticker-run .star {
    color: var(--gold-soft);
    font-style: normal;
    font-size: 14px;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-25%); }
  }

  @media (max-width: 1280px) {
    .hero-content { padding: 160px 32px 48px; }
    .hero-strip { padding: 24px 32px; }
    .plate-index { left: 32px; }
    .strip-left { gap: 32px; }
  }
  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
    }

    /* Full-bleed video background — shifted right to show subject */
    .hero-plate {
      position: absolute;
      inset: 0;
    }
    .hero-plate video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 80% center;
    }
    .hero-scrim {
      display: block;
      background: linear-gradient(180deg,
        rgba(14,26,29,0.3) 0%,
        rgba(14,26,29,0.55) 50%,
        rgba(14,26,29,0.85) 100%);
    }
    .hero-scrim-bottom { display: none; }

    .plate-index {
      top: 12px;
      left: 14px;
    }
    .plate-index-num { font-size: 28px; }
    .plate-index-label { font-size: 8px; }

    .hero-content {
      padding: 120px 20px 36px;
      min-height: 100svh;
      justify-content: flex-end;
    }
    .hero-title {
      font-size: clamp(44px, 12vw, 72px);
      margin-bottom: 16px;
    }
    .hero-lede { font-size: 16px; margin-bottom: 28px; }
    .hero-actions { flex-direction: column; gap: 10px; }
    .btn { width: 100%; justify-content: center; }

    .hero-strip {
      padding: 20px;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .strip-left {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .strip-right { align-items: flex-start; text-align: left; }

    .ticker-run { gap: 24px; font-size: 20px; }
  }
</style>
