---
const nav = [
  { label: 'Samling',     href: '#samling' },
  { label: 'Utställning', href: '#utstallning' },
  { label: 'Konstnärer',  href: '#konstnarer' },
  { label: 'Förvärva',    href: '#forvärva' },
];
---

<header class="masthead" id="masthead">
  <div class="masthead-inner">

    <div class="mark">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M12 2 L22 18 L2 18 Z" stroke="currentColor" stroke-width="1.4" fill="none"/>
        <circle cx="12" cy="13" r="2" fill="currentColor"/>
      </svg>
      <span class="wordmark">Olympus Gallery</span>
      <span class="est">Est. MMXIX</span>
    </div>

    <nav class="nav" aria-label="Primary">
      {nav.map((item, i) => (
        <a href={item.href}>
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="meta">
      <span class="pulse" aria-hidden="true"></span>
      <span>Öppet för förvärv · MMXXVI</span>
    </div>

  </div>
</header>

<style>
  .masthead {
    position: sticky;
    top: 0;
    z-index: 40;
    transition: background .3s ease, color .3s ease, border-color .3s ease;
    background: linear-gradient(180deg, rgba(14,22,25,0.55), rgba(14,22,25,0));
    color: #f4ecde;
    border-bottom: 1px solid rgba(244,236,222,0);
    backdrop-filter: blur(4px);
  }
  .masthead.solid {
    background: color-mix(in oklab, var(--cream) 86%, transparent);
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    backdrop-filter: blur(8px);
  }
  @media (max-width: 768px) {
    .masthead-inner {
      grid-template-columns: 1fr auto;
      padding: 14px 20px;
    }
    .nav { display: none; }
    .meta { display: none; }
    .wordmark { font-size: 18px; }
    .est { display: none; }
  }
  .masthead-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 16px 40px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }
  .mark {
    display: flex;
    align-items: center;
    gap: 10px;
    color: inherit;
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .est {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    opacity: .7;
    text-transform: uppercase;
    padding-left: 10px;
    margin-left: 4px;
    border-left: 1px solid currentColor;
    border-color: color-mix(in oklab, currentColor 30%, transparent);
  }
  .nav {
    display: flex;
    gap: 28px;
    justify-self: center;
  }
  .nav a {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    transition: color .2s ease;
    opacity: .92;
  }
  .nav a:hover { color: var(--gold); }
  .nav .num {
    font-family: var(--font-mono);
    font-size: 9px;
    opacity: .6;
    letter-spacing: 0.1em;
  }
  .meta {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    opacity: .8;
    text-transform: uppercase;
  }
  .pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 0 rgba(201,163,91,0.7);
    animation: pulse 2.4s ease-out infinite;
  }
</style>
